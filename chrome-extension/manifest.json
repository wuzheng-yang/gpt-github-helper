{
  "manifest_version": 3,
  "name": "GPT GitHub Helper Full",
  "version": "1.3.1",
  "description": "检测 ChatGPT 回答状态，保存会话内容，并辅助确认 GitHub 工具请求",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "http://127.0.0.1:18888/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "network_watcher.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "config.js",
        "page_reader.js",
        "network_bridge.js",
        "local_api.js",
        "github_prompt.js",
        "safety_check.js",
        "panel.js",
        "content.js",
        "runtime_settings.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
